# Copy to .env. No API keys are required - all three data sources are free and keyless.

# Local SQLite database (Prisma). Relative paths are resolved from the prisma/ directory.
DATABASE_URL="file:./dev.db"

# Optional overrides (sensible defaults live in src/lib/config.ts):
# Annualized risk-free rate used for Sharpe/Sortino (decimal, e.g. 0.066 = 6.6%)
# RISK_FREE_RATE=0.066

# --- Deployment (optional) ---
# On a serverless host the local SQLite file is ephemeral. Point these at a
# Turso (libSQL) database and the app uses the libSQL driver adapter instead.
# TURSO_DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-token"

# If set, the /api/refresh NAV-warming endpoint requires this as a Bearer token
# (Vercel cron sends it automatically when configured as CRON_SECRET).
# CRON_SECRET="a-long-random-string"
